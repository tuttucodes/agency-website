# Supabase — get from https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key

# Optional: Slack/email webhook for new-lead notifications
LEAD_NOTIFY_WEBHOOK=

# Optional: Cloudflare Turnstile (https://dash.cloudflare.com/?to=/:account/turnstile)
# Site key is exposed to the browser; secret key must stay server-side.
# When unset, the Contact form skips human verification (dev-friendly).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: Upstash Redis for IP rate-limiting on the Contact form
# Create at https://console.upstash.com/redis
# When unset, the Contact form skips rate-limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
